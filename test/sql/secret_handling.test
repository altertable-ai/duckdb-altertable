# name: test/sql/secret_handling.test
# description: Test Altertable secret registration and attach handling
# group: [sql]

require altertable

require-env ALTERTABLE_TEST_HOST

require-env ALTERTABLE_TEST_PORT

require-env ALTERTABLE_TEST_USER

require-env ALTERTABLE_TEST_PASSWORD

require-env ALTERTABLE_TEST_SSL

# Create an explicitly named altertable secret and use it in ATTACH.
statement ok
CREATE SECRET altertable_test_secret (
    TYPE altertable,
    HOST '${ALTERTABLE_TEST_HOST}',
    PORT '${ALTERTABLE_TEST_PORT}',
    USER '${ALTERTABLE_TEST_USER}',
    PASSWORD '${ALTERTABLE_TEST_PASSWORD}',
    SSL '${ALTERTABLE_TEST_SSL}'
)

statement ok
ATTACH '' AS secret_attached_db (TYPE altertable, SECRET altertable_test_secret)

query I
SELECT COUNT(*) >= 0 FROM duckdb_databases() WHERE database_name = 'secret_attached_db'
----
1

statement ok
DETACH secret_attached_db

statement ok
DROP SECRET altertable_test_secret

# Create an unnamed default altertable secret and verify ATTACH without
# explicit credentials can use it.
statement ok
CREATE SECRET (
    TYPE altertable,
    HOST '${ALTERTABLE_TEST_HOST}',
    PORT '${ALTERTABLE_TEST_PORT}',
    USER '${ALTERTABLE_TEST_USER}',
    PASSWORD '${ALTERTABLE_TEST_PASSWORD}',
    SSL '${ALTERTABLE_TEST_SSL}'
)

statement ok
ATTACH '' AS default_secret_attached_db (TYPE altertable)

query I
SELECT COUNT(*) >= 0 FROM duckdb_databases() WHERE database_name = 'default_secret_attached_db'
----
1

statement ok
DETACH default_secret_attached_db

statement ok
DROP SECRET "__default_altertable"

# Explicitly named missing secret should fail with clear binder error.
statement error
ATTACH '' AS missing_secret_db (TYPE altertable, SECRET does_not_exist)
----
Secret with name "does_not_exist" not found
