# name: test/sql/regress_secret_quoting.test
# description: Regression test: secret values with special chars must survive DSN quoting roundtrip
# group: [sql]

require altertable

# HOST value is the literal string "bad" (with surrounding double-quote characters).
# Before the fix, AddConnectionOption emitted the raw value without quoting:
#   host="bad"
# The DSN parser's UnquoteDSNValue() saw a double-quoted token and stripped the
# quotes, so config.host became just: bad
# After the fix, the value is wrapped in single-quote escaping in the DSN:
#   host='"bad"'
# The parser roundtrips it correctly and config.host stays: "bad"
#
# We verify the fix by checking the connection error contains "bad" (with the
# literal double-quote characters), proving the host value was not stripped.
statement ok
CREATE SECRET __regress_quoting (
    TYPE altertable,
    HOST '"bad"',
    PORT '1',
    USER 'u',
    PASSWORD 'p',
    SSL 'false'
)

# ATTACH is lazy — the connection is not opened until the first query.
statement ok
ATTACH '' AS __regress_quoting_db (TYPE altertable, SECRET __regress_quoting)

# This query forces the connection open and must fail. The error from
# Arrow Flight / gRPC will include the host URI, which should contain
# the full "bad" string (with double-quote characters) after the fix.
statement error
SELECT * FROM __regress_quoting_db.main.t
----
"bad"

statement ok
DETACH __regress_quoting_db

statement ok
DROP SECRET __regress_quoting
