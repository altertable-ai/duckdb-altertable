# name: test/sql/connection_validation.test
# description: Connection option validation that fails before network use
# group: [sql]

require altertable

statement error
SELECT * FROM altertable_query('port=not_a_number', 'SELECT 1')
----
Invalid ALTERTABLE port value 'not_a_number'

statement error
SELECT * FROM altertable_query('port=70000', 'SELECT 1')
----
Invalid ALTERTABLE port value '70000'

statement error
SELECT * FROM altertable_query('ssl=maybe', 'SELECT 1')
----
Invalid ALTERTABLE ssl value 'maybe'
