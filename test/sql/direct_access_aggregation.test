# name: test/sql/direct_access_aggregation.test
# description: Test direct table access with aggregation functions
# group: [sql]

require altertable

require-env ALTERTABLE_TEST_HOST

require-env ALTERTABLE_TEST_PORT

require-env ALTERTABLE_TEST_USER

require-env ALTERTABLE_TEST_PASSWORD

require-env ALTERTABLE_TEST_SSL

# Attach database
statement ok
ATTACH 'host=${ALTERTABLE_TEST_HOST} port=${ALTERTABLE_TEST_PORT} user=${ALTERTABLE_TEST_USER} password=${ALTERTABLE_TEST_PASSWORD} ssl=${ALTERTABLE_TEST_SSL}' AS test_db (TYPE ALTERTABLE)

# Create test table
statement ok
CALL altertable_execute('test_db', 'DROP TABLE IF EXISTS test_table_agg')

statement ok
CALL altertable_execute('test_db', 'CREATE TABLE test_table_agg (id INTEGER, category VARCHAR, amount DOUBLE)')

statement ok
CALL altertable_execute('test_db', 'INSERT INTO test_table_agg VALUES (1, ''A'', 100.00), (2, ''B'', 200.00), (3, ''A'', 150.00), (4, ''B'', 250.00), (5, ''A'', 175.00)')

# Test COUNT on specific column instead of COUNT(*)
query I
SELECT COUNT(id) FROM test_db.main.test_table_agg
----
5

# Test SUM
query R
SELECT SUM(amount) FROM test_db.main.test_table_agg
----
875.0

# Test AVG
query R
SELECT AVG(amount) FROM test_db.main.test_table_agg
----
175.0

# Test MIN and MAX
query RR
SELECT MIN(amount), MAX(amount) FROM test_db.main.test_table_agg
----
100.0	250.0

# Test GROUP BY with aggregation
query TR
SELECT category, SUM(amount) FROM test_db.main.test_table_agg GROUP BY category ORDER BY category
----
A	425.0
B	450.0

# Test GROUP BY with multiple aggregations
query TIR
SELECT category, COUNT(*), AVG(amount) FROM test_db.main.test_table_agg GROUP BY category ORDER BY category
----
A	3	141.666667
B	2	225.0

# Test HAVING clause
query TR
SELECT category, SUM(amount) as total FROM test_db.main.test_table_agg GROUP BY category HAVING SUM(amount) > 430 ORDER BY category
----
B	450.0

# Test aggregation with WHERE clause
query R
SELECT SUM(amount) FROM test_db.main.test_table_agg WHERE category = 'A'
----
425.0

# Test COUNT DISTINCT
query I
SELECT COUNT(DISTINCT category) FROM test_db.main.test_table_agg
----
2

# Cleanup
statement ok
CALL altertable_execute('test_db', 'DROP TABLE test_table_agg')

statement ok
DETACH test_db
