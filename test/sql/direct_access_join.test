# name: test/sql/direct_access_join.test
# description: Test direct table access with JOIN operations
# group: [sql]

require altertable

require-env ALTERTABLE_TEST_HOST

require-env ALTERTABLE_TEST_PORT

require-env ALTERTABLE_TEST_USER

require-env ALTERTABLE_TEST_PASSWORD

require-env ALTERTABLE_TEST_SSL

# Attach database
statement ok
ATTACH 'host=${ALTERTABLE_TEST_HOST} port=${ALTERTABLE_TEST_PORT} user=${ALTERTABLE_TEST_USER} password=${ALTERTABLE_TEST_PASSWORD} ssl=${ALTERTABLE_TEST_SSL}' AS test_db (TYPE ALTERTABLE)

# Create products table
statement ok
CALL altertable_execute('test_db', 'DROP TABLE IF EXISTS test_products')

statement ok
CALL altertable_execute('test_db', 'CREATE TABLE test_products (product_id INTEGER, name VARCHAR, price DOUBLE)')

statement ok
CALL altertable_execute('test_db', 'INSERT INTO test_products VALUES (1, ''Product A'', 19.99), (2, ''Product B'', 29.50), (3, ''Product C'', 15.00)')

# Create orders table
statement ok
CALL altertable_execute('test_db', 'DROP TABLE IF EXISTS test_orders')

statement ok
CALL altertable_execute('test_db', 'CREATE TABLE test_orders (order_id INTEGER, product_id INTEGER, quantity INTEGER)')

statement ok
CALL altertable_execute('test_db', 'INSERT INTO test_orders VALUES (100, 1, 5), (101, 3, 2), (102, 1, 3), (103, 2, 1)')

# Simple INNER JOIN
query IITI
SELECT o.order_id, p.name, o.quantity, o.product_id 
FROM test_db.main.test_orders o 
JOIN test_db.main.test_products p ON o.product_id = p.product_id 
ORDER BY o.order_id
----
100	Product A	5	1
101	Product C	2	3
102	Product A	3	1
103	Product B	1	2

# JOIN with aggregation
query TI
SELECT p.name, SUM(o.quantity) as total_quantity
FROM test_db.main.test_orders o
JOIN test_db.main.test_products p ON o.product_id = p.product_id
GROUP BY p.name
ORDER BY p.name
----
Product A	8
Product B	1
Product C	2

# JOIN with calculated columns
query TR
SELECT p.name, SUM(o.quantity * p.price) as total_revenue
FROM test_db.main.test_orders o
JOIN test_db.main.test_products p ON o.product_id = p.product_id
GROUP BY p.name
ORDER BY p.name
----
Product A	159.92
Product B	29.5
Product C	30.0

# JOIN with WHERE clause
query ITI
SELECT o.order_id, p.name, o.quantity
FROM test_db.main.test_orders o
JOIN test_db.main.test_products p ON o.product_id = p.product_id
WHERE o.quantity > 2
ORDER BY o.order_id
----
100	Product A	5
102	Product A	3

# Create customers table for multiple JOINs
statement ok
CALL altertable_execute('test_db', 'DROP TABLE IF EXISTS test_customers')

statement ok
CALL altertable_execute('test_db', 'CREATE TABLE test_customers (customer_id INTEGER, customer_name VARCHAR)')

statement ok
CALL altertable_execute('test_db', 'INSERT INTO test_customers VALUES (1, ''Alice''), (2, ''Bob'')')

# Create orders table with customer_id
statement ok
CALL altertable_execute('test_db', 'DROP TABLE IF EXISTS test_orders_with_cust')

statement ok
CALL altertable_execute('test_db', 'CREATE TABLE test_orders_with_cust (order_id INTEGER, customer_id INTEGER, product_id INTEGER, quantity INTEGER)')

statement ok
CALL altertable_execute('test_db', 'INSERT INTO test_orders_with_cust VALUES (100, 1, 1, 5), (101, 2, 3, 2), (102, 1, 1, 3), (103, 2, 2, 1)')

# Multiple JOINs
query ITTI
SELECT c.customer_name, o.order_id, p.name, o.quantity
FROM test_db.main.test_orders_with_cust o
JOIN test_db.main.test_products p ON o.product_id = p.product_id
JOIN test_db.main.test_customers c ON o.customer_id = c.customer_id
ORDER BY c.customer_name, o.order_id
----
Alice	100	Product A	5
Alice	102	Product A	3
Bob	101	Product C	2
Bob	103	Product B	1

# Aggregation with multiple JOINs
query TI
SELECT c.customer_name, SUM(o.quantity) as total_items
FROM test_db.main.test_orders_with_cust o
JOIN test_db.main.test_customers c ON o.customer_id = c.customer_id
GROUP BY c.customer_name
ORDER BY c.customer_name
----
Alice	8
Bob	3

# LEFT JOIN to show products with no orders (using original orders table)
statement ok
CALL altertable_execute('test_db', 'INSERT INTO test_products VALUES (4, ''Product D'', 50.0)')

query TI
SELECT p.name, COALESCE(SUM(CASE WHEN o.order_id IS NOT NULL THEN 1 ELSE 0 END), 0) as order_count
FROM test_db.main.test_products p
LEFT JOIN test_db.main.test_orders o ON p.product_id = o.product_id
GROUP BY p.name
ORDER BY p.name
----
Product A	2
Product B	1
Product C	1
Product D	0

# Cleanup
statement ok
CALL altertable_execute('test_db', 'DROP TABLE test_orders_with_cust')

statement ok
CALL altertable_execute('test_db', 'DROP TABLE test_orders')

statement ok
CALL altertable_execute('test_db', 'DROP TABLE test_products')

statement ok
CALL altertable_execute('test_db', 'DROP TABLE test_customers')

statement ok
DETACH test_db
