# name: test/sql/attached_writes.test
# description: Attached Altertable DDL and INSERT/CTAS support
# group: [sql]

require altertable

require-env ALTERTABLE_TEST_HOST

require-env ALTERTABLE_TEST_PORT

require-env ALTERTABLE_TEST_USER

require-env ALTERTABLE_TEST_PASSWORD

require-env ALTERTABLE_TEST_SSL

statement ok
ATTACH 'host=${ALTERTABLE_TEST_HOST} port=${ALTERTABLE_TEST_PORT} user=${ALTERTABLE_TEST_USER} password=${ALTERTABLE_TEST_PASSWORD} ssl=${ALTERTABLE_TEST_SSL}' AS write_db (TYPE ALTERTABLE)

statement ok
CALL altertable_execute('write_db', 'DROP TABLE IF EXISTS __attached_writes')

statement ok
CALL altertable_execute('write_db', 'DROP TABLE IF EXISTS __attached_ctas')

statement ok
CALL altertable_execute('write_db', 'DROP TABLE IF EXISTS __attached_large_insert')

statement ok
CREATE TABLE write_db.main.__attached_writes (id INTEGER, name VARCHAR)

statement ok
INSERT INTO write_db.main.__attached_writes VALUES (1, 'alpha'), (2, 'beta')

statement ok
INSERT INTO write_db.main.__attached_writes SELECT 3, 'gamma'

query IT
SELECT id, name FROM write_db.main.__attached_writes ORDER BY id
----
1	alpha
2	beta
3	gamma

statement ok
ALTER TABLE write_db.main.__attached_writes ADD COLUMN score DOUBLE

statement ok
INSERT INTO write_db.main.__attached_writes (id, name, score) VALUES (4, 'delta', 4.5)

query ITR
SELECT id, name, score FROM write_db.main.__attached_writes WHERE id = 4
----
4	delta	4.5

statement ok
CREATE TABLE write_db.main.__attached_ctas AS SELECT i::INTEGER AS id, ('v' || i::VARCHAR) AS name FROM range(3) tbl(i)

query IT
SELECT id, name FROM write_db.main.__attached_ctas ORDER BY id
----
0	v0
1	v1
2	v2

statement ok
CREATE TABLE write_db.main.__attached_large_insert (id BIGINT)

statement ok
INSERT INTO write_db.main.__attached_large_insert SELECT i FROM range(3000) tbl(i)

query II
SELECT COUNT(*), MAX(id) FROM write_db.main.__attached_large_insert
----
3000	2999

statement error
UPDATE write_db.main.__attached_writes SET name = 'updated' WHERE id = 1
----
UPDATE of Altertable attached tables is not supported

statement error
DELETE FROM write_db.main.__attached_writes WHERE id = 1
----
DELETE from Altertable attached tables is not supported

statement ok
DROP TABLE write_db.main.__attached_large_insert

statement ok
DROP TABLE write_db.main.__attached_ctas

statement ok
DROP TABLE write_db.main.__attached_writes

statement ok
DETACH write_db
